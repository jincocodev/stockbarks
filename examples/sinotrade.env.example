# Shioaji（永豐金證券）API 憑證
# 申請 API: https://www.sinotrade.com.tw/CSCenter/CSCenter_13_8

SINOPAC_API_KEY=your_api_key_here
SINOPAC_SECRET_KEY=your_secret_key_here

# 身分證字號（同 CA 密碼預設）
SINOPAC_PERSON_ID=A123456789

# 證券帳號（XX-XXXXXXX 格式）
SINOPAC_ACCOUNT=00-0000000

# CA 密碼（通常 = 身分證）
SINOPAC_CA_PASSWD=A123456789
